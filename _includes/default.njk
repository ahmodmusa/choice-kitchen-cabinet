<!DOCTYPE html>
<html lang="en">
<head>

{% include 'head.njk' %}

<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --cream: #F8F4ED;
    --cream-dark: #EDE7DA;
    --walnut: #3D2B1F;
    --walnut-light: #6B4226;
    --copper: #B5651D;
    --copper-light: #D4845A;
    --charcoal: #2C2420;
    --warm-gray: #8A7B72;
    --warm-white: #FDFAF5;
    --text-body: #4A3728;
    --serif: 'Playfair Display', Georgia, serif;
    --sans: 'DM Sans', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--warm-white);
    color: var(--text-body);
    overflow-x: hidden;
    overflow-wrap: break-word;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 8%; }

  .breadcrumbs {
    padding: 20px 8%;
    background: var(--cream);
    border-bottom: 1px solid rgba(61,43,31,0.1);
  }

  .breadcrumbs-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.9em;
  }

  .breadcrumb-item {
    display: flex;
    align-items: center;
  }

  .breadcrumb-item:not(:last-child)::after {
    content: '>';
    margin: 0 12px;
    color: var(--text-muted);
    font-size: 0.8em;
  }

  .breadcrumb-item a {
    color: var(--walnut);
    text-decoration: none;
    transition: color 0.3s;
  }

  .breadcrumb-item a:hover {
    color: var(--copper);
  }

  .breadcrumb-item span {
    color: var(--text-muted);
  }

  .hero {
    min-height: 90vh;
    padding: 100px 5% 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 80px;
    background: linear-gradient(135deg, var(--cream) 0%, var(--cream-dark) 100%);
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -10%;
    right: -5%;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(181,101,29,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -10%;
    left: -5%;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(61,43,31,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-text {
    text-align: left;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, rgba(181,101,29,0.15) 0%, rgba(181,101,29,0.08) 100%);
    color: var(--copper);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 8px 20px;
    border-radius: 50px;
    margin-bottom: 28px;
    white-space: nowrap;
    border: 1px solid rgba(181,101,29,0.2);
    box-shadow: 0 4px 12px rgba(181,101,29,0.1);
  }

  .hero-badge-dot {
    width: 8px;
    height: 8px;
    background: var(--copper);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.1); }
  }

  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(42px, 5vw, 64px);
    line-height: 1.1;
    color: var(--walnut);
    margin-bottom: 24px;
    font-weight: 600;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--copper);
    background: linear-gradient(135deg, var(--copper) 0%, var(--copper-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 17px;
    line-height: 1.8;
    color: var(--warm-gray);
    margin-bottom: 40px;
    max-width: 480px;
  }

  .hero-btns {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--walnut) 0%, var(--charcoal) 100%);
    color: #fff;
    padding: 16px 36px;
    border-radius: 50px;
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 8px 24px rgba(61,43,31,0.25);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, var(--copper) 0%, var(--walnut-light) 100%);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(181,101,29,0.35);
  }

  .hero-btns .btn-primary {
    background: linear-gradient(135deg, var(--walnut) 0%, var(--charcoal) 100%);
    color: #fff !important;
    border: none;
    box-shadow: 0 8px 24px rgba(61,43,31,0.25);
  }

  .hero-btns .btn-primary:hover {
    background: linear-gradient(135deg, var(--copper) 0%, var(--walnut-light) 100%);
    box-shadow: 0 12px 32px rgba(181,101,29,0.35);
  }

  .hero-btns .btn-primary svg {
    fill: #fff !important;
  }

  .btn-secondary {
    color: var(--walnut);
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 28px;
    border-radius: 50px;
    border: 2px solid var(--walnut);
    transition: all 0.3s;
    background: rgba(61,43,31,0.06);
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(61,43,31,0.1);
  }

  .btn-secondary:hover {
    background: var(--walnut);
    color: var(--cream);
    border-color: var(--walnut);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(61,43,31,0.25);
  }

  .hero-btns .btn-secondary {
    color: var(--walnut);
    border: 2px solid var(--walnut);
    background: rgba(61,43,31,0.06);
  }

  .hero-btns .btn-secondary:hover {
    background: var(--walnut);
    color: var(--cream);
    border-color: var(--walnut);
  }

  .hero-visual {
    position: relative;
    z-index: 1;
  }

  .hero-slider {
    position: relative;
    width: 100%;
    max-width: 600px;
  }

  .hero-slide {
    display: none;
    width: 100%;
  }

  .hero-slide.active {
    display: block;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: 0 24px 64px rgba(61,43,31,0.2);
    transform: perspective(1000px) rotateY(-5deg);
    transition: transform 0.5s ease, opacity 0.5s ease;
  }

  .hero-image:hover {
    transform: perspective(1000px) rotateY(0deg);
  }

  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
  }

  .slider-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--walnut);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s;
  }

  .slider-dot.active {
    background: var(--walnut);
  }

  .slider-dot:hover {
    background: var(--walnut);
  }

  .freebies-section {
    padding: 80px 8%;
    background: var(--cream);
  }

  .freebies-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .freebies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .freebie-card {
    background: var(--warm-white);
    border: 1px solid rgba(61,43,31,0.08);
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    transition: all 0.3s ease;
    position: relative;
    box-shadow: 0 4px 16px rgba(61,43,31,0.06);
  }

  .freebie-card:hover {
    border-color: rgba(181,101,29,0.3);
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(61,43,31,0.12);
  }

  .freebie-badge {
    position: absolute;
    top: -10px;
    right: 16px;
    background: linear-gradient(135deg, var(--copper) 0%, var(--walnut-light) 100%);
    color: var(--cream);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 50px;
    box-shadow: 0 4px 12px rgba(181,101,29,0.3);
  }

  .freebie-icon-wrap {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, rgba(181,101,29,0.12) 0%, rgba(61,43,31,0.08) 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
  }

  .freebie-icon-wrap svg {
    width: 24px;
    height: 24px;
    color: var(--copper);
  }

  .freebie-text {
    font-size: 15px;
    font-weight: 600;
    color: var(--walnut);
    line-height: 1.5;
  }

  .feature-card, .product-card, .testi-card, .process-step, .city-card, .freebie-card, .gallery-item { min-width: 0; }

  .section { padding: 96px 8%; }

  .section-header { text-align: center; margin-bottom: 60px; }

  .section-eyebrow {
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--copper); font-weight: 500; margin-bottom: 12px;
  }

  .section-title {
    font-family: var(--serif); font-size: clamp(28px, 3vw, 42px);
    color: var(--walnut); line-height: 1.2; margin-bottom: 14px;
  }

  .section-desc { font-size: 15px; color: var(--warm-gray); max-width: 540px; margin: 0 auto; line-height: 1.7; }

  .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }

  .feature-card {
    background: var(--cream); border: 1px solid rgba(61,43,31,0.08);
    border-radius: 16px; padding: 28px; transition: transform 0.2s, box-shadow 0.2s;
  }

  .feature-card:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(61,43,31,0.1); }

  .feature-icon {
    width: 44px; height: 44px; background: rgba(181,101,29,0.1); border-radius: 10px;
    display: flex; align-items: center; justify-content: center; margin-bottom: 16px; font-size: 20px;
  }

  .feature-title { font-family: var(--serif); font-size: 18px; color: var(--walnut); margin-bottom: 8px; }
  .feature-desc { font-size: 14px; line-height: 1.65; color: var(--warm-gray); }

  .section-alt { background: var(--cream); padding: 96px 8%; }

  .process-steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0; position: relative; }

  .process-step { padding: 32px 24px; position: relative; text-align: center; }

  .step-num { font-family: var(--serif); font-size: 48px; color: rgba(181,101,29,0.15); font-weight: 600; line-height: 1; margin-bottom: 16px; }
  .step-title { font-family: var(--serif); font-size: 17px; color: var(--walnut); margin-bottom: 8px; }
  .step-desc { font-size: 13px; color: var(--warm-gray); line-height: 1.6; }

  .testimonials-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }

  .testi-card {
    background: var(--cream); border-radius: 16px; padding: 28px;
    border: 1px solid rgba(61,43,31,0.08); position: relative;
  }

  .testi-quote { font-family: var(--serif); font-size: 38px; color: var(--copper); line-height: 1; margin-bottom: 12px; opacity: 0.4; }
  .testi-text { font-size: 14px; line-height: 1.7; color: var(--text-body); margin-bottom: 20px; }
  .testi-author { display: flex; align-items: center; gap: 10px; }
  .testi-avatar {
    width: 36px; height: 36px; border-radius: 50%; background: var(--walnut);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--serif); font-size: 13px; color: var(--copper-light); font-weight: 600;
  }
  .testi-name { font-size: 13px; font-weight: 500; color: var(--walnut); }
  .testi-stars { font-size: 11px; color: var(--copper); letter-spacing: 2px; }

  .faq-list { max-width: 720px; margin: 0 auto; }
  .faq-item { border-bottom: 1px solid rgba(61,43,31,0.1); overflow: hidden; }

  .faq-q {
    width: 100%; background: none; border: none; padding: 22px 0;
    font-family: var(--sans); font-size: 15px; font-weight: 500; color: var(--walnut);
    text-align: left; cursor: pointer; display: flex; justify-content: space-between; align-items: center;
    gap: 16px; transition: color 0.2s;
  }

  .faq-q:hover { color: var(--copper); }
  .faq-chevron { width: 20px; height: 20px; flex-shrink: 0; color: var(--warm-gray); transition: transform 0.3s; }

  .faq-a {
    font-size: 14px; line-height: 1.7; color: var(--warm-gray);
    max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s;
  }

  .faq-item.open .faq-a { max-height: 500px; padding-bottom: 20px; }
  .faq-item.open .faq-chevron { transform: rotate(180deg); }
  .faq-item.open .faq-q { color: var(--copper); }

  .cta-banner {
    background: var(--walnut); padding: 80px 5%; text-align: center; position: relative; overflow: hidden;
  }

  .cta-banner::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at center, rgba(181,101,29,0.2) 0%, transparent 70%);
  }

  .cta-banner h2 { font-family: var(--serif); font-size: clamp(28px, 3.5vw, 46px); color: var(--cream); margin-bottom: 14px; position: relative; }
  .cta-banner p { font-size: 15px; color: rgba(253,250,245,0.65); margin-bottom: 36px; position: relative; }

  .btn-wa {
    background: #25D366; color: white; padding: 16px 36px; border-radius: 50px;
    font-size: 16px; font-weight: 500; border: none; cursor: pointer;
    display: inline-flex; align-items: center; gap: 10px; transition: all 0.3s;
    text-decoration: none; position: relative; font-family: var(--sans);
    box-shadow: 0 8px 24px rgba(37,211,102,0.3);
  }

  .btn-wa:hover { background: #1ebe5d; transform: translateY(-3px); box-shadow: 0 12px 32px rgba(37,211,102,0.4); }

  .areas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }

  .city-card {
    background: var(--cream);
    border: 1px solid rgba(61,43,31,0.1);
    border-radius: 8px;
    padding: 20px;
    text-decoration: none;
    color: var(--walnut);
    transition: all 0.2s;
  }

  .city-card:hover {
    box-shadow: 0 2px 8px rgba(61,43,31,0.1);
    border-color: rgba(61,43,31,0.2);
  }

  .city-card-title {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--walnut);
  }

  .city-card-areas {
    list-style: none;
    padding: 0;
    margin: 0 0 12px 0;
  }

  .city-card-areas li {
    padding: 8px 0;
    border-bottom: 1px solid rgba(61,43,31,0.05);
    font-size: 14px;
  }

  .city-card-areas li:last-child {
    border-bottom: none;
  }

  .city-card-areas a {
    color: var(--walnut);
    text-decoration: none;
    transition: color 0.2s;
  }

  .city-card-areas a:hover {
    color: var(--copper);
  }

  .see-more-link {
    font-size: 13px;
    color: var(--copper);
    text-decoration: none;
    font-weight: 500;
    display: inline-block;
  }

  .see-more-link:hover {
    text-decoration: underline;
  }

  .products-section {
    background: var(--cream);
    padding: 96px 8%;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
  }

  .product-card {
    background: white;
    border: 1px solid rgba(61,43,31,0.08);
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    transition: all 0.3s;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--copper), var(--copper-light));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .product-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(61,43,31,0.15);
    border-color: rgba(181,101,29,0.4);
  }

  .product-card:hover::before {
    opacity: 1;
  }

  .product-icon {
    width: 72px;
    height: 72px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cream);
    border-radius: 16px;
    transition: all 0.3s;
  }

  .product-card:hover .product-icon {
    background: rgba(181,101,29,0.1);
    transform: scale(1.05);
  }

  .product-icon svg {
    width: 40px;
    height: 40px;
    fill: var(--walnut);
    transition: fill 0.3s;
  }

  .product-card:hover .product-icon svg {
    fill: var(--copper);
  }

  .product-name {
    font-family: var(--serif);
    font-size: 17px;
    font-weight: 600;
    color: var(--walnut);
    margin: 0;
    transition: color 0.3s;
  }

  .product-card:hover .product-name {
    color: var(--copper);
  }

  /* Recent Work Gallery */
  .gallery-section {
    padding: 96px 8%;
    background: var(--warm-white);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 16px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .gallery-grid-compact {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 8px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    aspect-ratio: 1;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(61,43,31,0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .gallery-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 32px rgba(61,43,31,0.2);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.1);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(61,43,31,0.9) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: flex-end;
    padding: 20px;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-overlay-text {
    font-size: 14px;
    font-weight: 500;
    color: var(--cream);
    transform: translateY(10px);
    transition: transform 0.3s ease;
  }

  .gallery-item:hover .gallery-overlay-text {
    transform: translateY(0);
  }

  /* Lightbox Modal */
  .lightbox-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(44, 36, 32, 0.92);
    align-items: center;
    justify-content: center;
    padding: 24px;
    animation: lbFadeIn 0.25s ease;
  }

  .lightbox-modal.active {
    display: flex;
  }

  .lightbox-modal img {
    max-width: 100%;
    max-height: 85vh;
    border-radius: 12px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.4);
    object-fit: contain;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: rgba(253,250,245,0.15);
    border: none;
    color: var(--cream);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    transition: background 0.2s;
    padding: 0;
  }

  .lightbox-close:hover {
    background: rgba(253,250,245,0.3);
  }

  .lightbox-caption {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--cream);
    font-size: 14px;
    background: rgba(44,36,32,0.7);
    padding: 8px 20px;
    border-radius: 50px;
    white-space: nowrap;
    max-width: 90vw;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @keyframes lbFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* SEO Article Section */
  .seo-article {
    padding: 96px 8%;
    background: var(--cream);
  }

  .seo-article-content {
    max-width: 900px;
    margin: 0 auto;
  }

  .seo-article h2 {
    font-family: var(--serif);
    font-size: clamp(28px, 3vw, 36px);
    color: var(--walnut);
    margin-bottom: 24px;
    line-height: 1.3;
  }

  .seo-article p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-body);
